# ============================================================
# vokabelbox – Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die Werte.
# Die NEXT_PUBLIC_* Variablen werden im Browser sichtbar,
# alle anderen nur serverseitig (API-Routes, Server Actions).
# ============================================================

# ---------- Supabase ----------
# Aus Supabase-Dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# NIEMALS im Client verwenden. Nur in serverseitigem Code,
# z.B. für Admin-Operationen oder wenn RLS umgangen werden muss.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- Anthropic ----------
# Aus console.anthropic.com → API Keys
# NIEMALS im Client verwenden, API-Routes only.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------- App ----------
# Für Auth-Callbacks / absolute URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
